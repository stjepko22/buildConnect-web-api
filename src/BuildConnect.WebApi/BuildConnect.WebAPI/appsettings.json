{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "BuildConnectDb": "Server=(localdb)\\MSSQLLocalDB;Database=BuildConnectDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "DatabaseStartup": {
    "ApplyMigrationsOnStartup": false,
    "SeedOnStartup": false
  },
  "Jwt": {
    "Issuer": "BuildConnect",
    "Audience": "BuildConnectClient",
    "SigningKey": "BuildConnect.DevOnly.JwtSigningKey.2026.MustBeLongEnough",
    "ExpirationMinutes": 120
  },
  "AllowedHosts": "*"
}
